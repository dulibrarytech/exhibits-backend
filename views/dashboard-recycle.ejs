<%- include('partials/header.ejs'); %>
<body>
<%- include('partials/nav-dashboard.ejs'); %>
<div id="right-panel" class="right-panel">
    <%- include('partials/main-header.ejs'); %>
    <main id="main" class="content" tabindex="-1">
        <h1 class="visually-hidden">Recycle bin</h1>
        <div id="message"></div>

        <%# Hidden until the access gate confirms the user is an administrator. %>
        <div id="recycle-content" style="display:none">

            <div class="card">
                <div class="card-header">
                    <strong class="card-title">Recycle Bin</strong>
                </div>
                <div class="card-body">
                    <p class="text-muted">
                        Soft-deleted exhibits and items. <strong>Restore</strong> returns a record to its
                        owner; <strong>Permanently Delete</strong> removes it for good. Media files are not
                        affected and are reclaimed separately.
                    </p>

                    <div id="recycled-table-wrap" style="display:none">
                        <table id="recycled" class="display">
                            <thead>
                            <tr>
                                <th scope="col">Title</th>
                                <th scope="col">Owner</th>
                                <th scope="col">Actions</th>
                            </tr>
                            </thead>
                            <tbody id="recycled-data"></tbody>
                        </table>
                    </div>

                    <div id="recycle-pager" class="d-flex align-items-center mt-3" style="display:none">
                        <button type="button" id="recycle-prev" class="btn btn-sm btn-secondary">Prev</button>
                        <span id="recycle-page-info" class="mx-3 text-muted"></span>
                        <button type="button" id="recycle-next" class="btn btn-sm btn-secondary">Next</button>
                    </div>

                    <p id="recycle-empty-state" class="mb-0" style="display:none">
                        <em>The recycle bin is empty.</em>
                    </p>

                    <button type="button" id="refresh-recycle" class="btn btn-secondary mt-3">
                        <i class="fa fa-refresh" aria-hidden="true"></i> Refresh
                    </button>
                </div>
            </div>

            <div class="card mt-4 border-danger">
                <div class="card-header">
                    <strong class="card-title text-danger">Empty Recycle Bin</strong>
                </div>
                <div class="card-body">
                    <p>
                        Permanently deletes <strong>every</strong> record in the recycle bin. This cannot be undone.
                    </p>
                    <button type="button" id="empty-recycle" class="btn btn-danger"
                            data-toggle="modal" data-target="#empty-confirm-modal">
                        <i class="fa fa-exclamation-triangle" aria-hidden="true"></i> Empty Recycle Bin…
                    </button>
                </div>
            </div>

        </div>
    </main>
    <div class="clearfix"></div>
    <%- include('partials/footer.ejs'); %>
</div>

<%# ── Single permanent-delete confirmation ── %>
<div class="modal fade" id="delete-confirm-modal" tabindex="-1" role="dialog"
     aria-labelledby="delete-confirm-title" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title h5" id="delete-confirm-title">Permanently delete record</h2>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p class="text-danger">
                    Permanently delete <strong><span id="delete-confirm-target">this record</span></strong>?
                    This cannot be undone.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="delete-confirm-btn">Permanently Delete</button>
            </div>
        </div>
    </div>
</div>

<%# ── Empty-bin confirmation (type-to-confirm) ── %>
<div class="modal fade" id="empty-confirm-modal" tabindex="-1" role="dialog"
     aria-labelledby="empty-confirm-title" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title h5" id="empty-confirm-title">Confirm empty recycle bin</h2>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p class="text-danger">
                    This permanently deletes every record in the recycle bin. Type <strong>EMPTY</strong> to confirm.
                </p>
                <label for="empty-confirm-input" class="visually-hidden">Type EMPTY to confirm</label>
                <input type="text" class="form-control" id="empty-confirm-input"
                       autocomplete="off" placeholder="EMPTY">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="empty-confirm-btn" disabled>Empty Recycle Bin</button>
            </div>
        </div>
    </div>
</div>

<style>
    /* Match the dashboard content typography used by the other views (Open Sans,
       0.875rem) so both cards' body text matches the index-management cards and the
       exhibits/item lists — in particular the Empty Recycle Bin card's bare <p>,
       which otherwise inherits the theme's larger default. Card titles and buttons
       keep their default size. */
    #recycle-content .card-body,
    #recycle-content .card-body p {
        font-family: 'Open Sans', sans-serif;
        font-size: 0.875rem;
    }

    /* Match the typography/density of the DataTables-based exhibits & item lists.
       Cells inherit the body font (Open Sans, 16px) exactly as those lists do; these
       rules replicate DataTables' cell metrics (padding, header weight, borders,
       stripe, hover) without needing the DataTables plugin on this page. */
    #recycled {
        width: 100%;
        margin: 0;
        border-spacing: 0;
        font-family: 'Open Sans', sans-serif;
    }
    #recycled thead th {
        padding: 10px;
        font-weight: bold;
        text-align: left;
        border-bottom: 1px solid rgba(0, 0, 0, 0.3);
    }
    #recycled tbody td {
        padding: 8px 10px;
        border-top: 1px solid rgba(0, 0, 0, 0.15);
        vertical-align: middle;
        font-size: 0.875rem;
    }
    /* Item-list-style Title cell: thumbnail / type-icon placeholder + title + type below */
    #recycled .recycle-cell {
        display: flex;
        align-items: center;
    }
    #recycled .recycle-thumb,
    #recycled .recycle-thumb-placeholder {
        width: 50px;
        height: 50px;
        border-radius: 4px;
        margin-right: 10px;
        flex-shrink: 0;
    }
    #recycled .recycle-thumb {
        object-fit: cover;
    }
    #recycled .recycle-thumb-placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f0f0f0;
        color: #999;
        font-size: 1.2rem;
    }
    #recycled .recycle-text {
        min-width: 0;
    }
    #recycled .recycle-title {
        font-weight: bold;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    #recycled .recycle-type {
        color: #6c757d;
    }
    #recycled tbody tr:first-child td {
        border-top: none;
    }
    #recycled tbody tr:nth-child(odd) td {
        background-color: rgba(0, 0, 0, 0.023);
    }
    #recycled tbody tr:hover td {
        background-color: rgba(0, 0, 0, 0.04);
    }
    /* Center the Actions column (header + kebab menus) */
    #recycled th:last-child,
    #recycled td:last-child {
        text-align: center;
    }
    /* Kebab actions menu: driven manually (no Popper). Right-align so it opens
       inward from the last column instead of overflowing past the table edge. */
    #recycled .recycle-actions-menu.dropdown-menu {
        right: 0;
        left: auto;
        margin-top: 0;
        white-space: nowrap;
    }
</style>
<!-- libs -->
<%- include('partials/exhibits-libs-common.ejs'); %>
<!-- app -->
<%- include('partials/exhibits-app-common.ejs'); %>
<script src="/exhibits-dashboard/static/app/dist/recycle.module.min.js?<%= build_version %>"></script>
<script>
    (async function () {
        await recycleModule.init();
    })();
</script>
</body>
</html>
