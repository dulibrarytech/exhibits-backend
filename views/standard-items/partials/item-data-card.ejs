<div id="item-data-card" class="card">
    <div class="card-header">
        <strong class="card-title mb-3">Item Data</strong>
        <div class="btn-group float-right">
            <span id="created" style="text-align: right; font-size: x-small"></span>
        </div>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-12 col-md-12">
                <div class="row form-group">
                    <div class="col-12">
                        <div class="form-text text-muted" style="font-size: 17px"><span id="is-required-text">Exhibit Text
                            <span class="badge badge-required">Required</span></span>
                            &nbsp;&nbsp;<a onclick="helperModule.preview_html('item-text-input');return false;" data-toggle="modal" data-target=".preview-html" class="btn-xs btn-light"><span style="padding: 5px"><i class="fa fa-code" aria-hidden="true"></i> <small>Preview Field</small></span></a>
                        </div>
                        <small class="form-text text-muted"><i class="fa fa-exclamation-circle" aria-hidden="true"></i> <em>This text is displayed directly on the exhibit template</em></small>
                        <textarea id="item-text-input" aria-labelledby="is-required-text" class="form-control" name="item_text_input"
                                  rows="4"></textarea>
                    </div>
                </div>
            </div>
        </div>
        <div class="row" id="is-media-only-description" style="display: none">
            <div class="col-12 col-md-12">
                <div class="row form-group">
                    <div class="col-12">
                        <div class="form-text text-muted" style="font-size: 17px"><span id="item-description-input-label">Pop-up Window Description <small><em>(Optional)</em></small></span>
                            &nbsp;&nbsp;<a onclick="helperModule.preview_html('item-description-input');return false;" data-toggle="modal" data-target=".preview-html" class="btn-xs btn-light"><span style="padding: 5px"><i class="fa fa-code" aria-hidden="true"></i> <small>Preview Field</small></span></a>
                        </div>
                        <textarea id="item-description-input" aria-labelledby="item-description-input-label" class="form-control" name="item_description_input"
                                  rows="4"></textarea>
                    </div>
                </div>
            </div>
        </div>
        <div class="row" id="is-media-only-caption" style="display: none">
            <div class="col-12 col-md-12">
                <div class="row form-group">
                    <div class="col-12">
                        <div class="form-text text-muted" style="font-size: 17px"><span id="item-caption-input-label">Caption
                            <small><em>(Optional)</em></small></span>
                            &nbsp;&nbsp;<a onclick="helperModule.preview_html('item-caption-input');return false;" data-toggle="modal" data-target=".preview-html" class="btn-xs btn-light"><span style="padding: 5px"><i class="fa fa-code" aria-hidden="true"></i> <small>Preview Field</small></span></a>
                        </div>
                        <textarea id="item-caption-input" aria-labelledby="item-caption-input-label" class="form-control" name="item_caption_input"
                                  rows="4"></textarea>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
