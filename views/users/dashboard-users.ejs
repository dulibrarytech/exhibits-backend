<%- include('../partials/header.ejs'); %>
<style>
    /* Paging nav - use inline-flex for connected button group */
    #users_wrapper .dt-paging nav {
        display: inline-flex;
    }

    /* Base button styling - match repo .page-link */
    #users_wrapper .dt-paging .dt-paging-button {
        display: inline-block;
        box-sizing: border-box;
        min-width: 1.5em;
        padding: 0.4rem 0.75rem !important;
        margin-left: -1px !important;
        font-size: 0.875rem !important;
        line-height: 1.5 !important;
        text-align: center;
        text-decoration: none !important;
        cursor: pointer;
        color: #7f7f7f !important;
        background: #fff !important;
        background-color: #fff !important;
        border: 1px solid #7f7f7f !important;
        border-radius: 0 !important;
        transition: all 0.15s ease-in-out;
        box-shadow: none !important;
    }

    /* First visible button (Previous) - rounded left corners */
    #users_wrapper .dt-paging .dt-paging-button.previous {
        margin-left: 0 !important;
        border-top-left-radius: 0.2rem !important;
        border-bottom-left-radius: 0.2rem !important;
    }

    /* Last visible button (Next) - rounded right corners */
    #users_wrapper .dt-paging .dt-paging-button.next {
        border-top-right-radius: 0.2rem !important;
        border-bottom-right-radius: 0.2rem !important;
    }

    /* Hover state - match repo .page-link:hover */
    #users_wrapper .dt-paging .dt-paging-button:hover {
        z-index: 2;
        color: #5f5f5f !important;
        text-decoration: none !important;
        background-color: #f0f0f0 !important;
        background: #f0f0f0 !important;
        border-color: #7f7f7f !important;
    }

    /* Active/current page - match repo .page-item.active .page-link */
    #users_wrapper .dt-paging .dt-paging-button.current,
    #users_wrapper .dt-paging .dt-paging-button.current:hover {
        z-index: 3;
        color: #fff !important;
        background-color: #7f7f7f !important;
        background: #7f7f7f !important;
        border-color: #7f7f7f !important;
    }

    /* Disabled state - match repo .page-item.disabled .page-link */
    #users_wrapper .dt-paging .dt-paging-button.disabled,
    #users_wrapper .dt-paging .dt-paging-button.disabled:hover,
    #users_wrapper .dt-paging .dt-paging-button.disabled:active {
        color: #b0b0b0 !important;
        pointer-events: none;
        cursor: default;
        background-color: #fff !important;
        background: #fff !important;
        border-color: #b0b0b0 !important;
        box-shadow: none !important;
    }

    /* Focus state - match repo .page-link:focus */
    #users_wrapper .dt-paging .dt-paging-button:focus {
        z-index: 3;
        outline: 0;
        box-shadow: 0 0 0 0.2rem rgba(127, 127, 127, 0.25) !important;
    }

    /* Ellipsis styling */
    #users_wrapper .dt-paging .ellipsis {
        display: inline-block;
        padding: 0.4rem 0.75rem;
        font-size: 0.875rem;
        line-height: 1.5;
        color: #b0b0b0;
        background-color: #fff;
        border: 1px solid #b0b0b0;
        margin-left: -1px;
    }

    /* Info row - add separator and match repo pagination-info */
    #users_wrapper .row:last-child {
        border-top: 1px solid #e9ecef;
        margin-top: 10px;
    }

    #users_wrapper .dt-info {
        font-size: 0.85rem;
        color: #6c757d;
        padding-top: 15px;
    }

    /* Length menu and search styling consistency */
    #users_wrapper .dt-length {
        font-size: 0.85rem;
        color: #6c757d;
    }

    #users_wrapper .dt-search {
        font-size: 0.85rem;
        color: #6c757d;
    }

    /* Push pagination buttons to the far right with top spacing */
    #users_wrapper .dt-paging {
        text-align: right;
        padding-top: 15px;
    }

    /* Responsive pagination adjustments */
    @media (max-width: 768px) {
        #users_wrapper .dt-paging .dt-paging-button {
            padding: 0.3rem 0.6rem !important;
            font-size: 0.8rem !important;
        }

        #users_wrapper .dt-paging .ellipsis {
            padding: 0.3rem 0.6rem;
            font-size: 0.8rem;
        }
    }
</style>
<body>
<%- include('../partials/nav-dashboard'); %>
<div id="right-panel" class="right-panel">
    <%- include('../partials/main-header.ejs'); %>
    <div class="content" style="min-height: 875px;">
        <div id="message"></div>
        <div id="user-card" class="card">
            <div class="card-header">
                <strong class="card-title mb-3">User Profiles</strong>
            </div>
            <div class="card-body">
                <table id="users" class="display compact">
                    <thead>
                    <tr>
                        <th>User</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody id="user-data"></tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="clearfix"></div>
    <%- include('../partials/footer.ejs'); %>
</div>
<!-- libs -->
<%- include('../partials/exhibits-libs-common.ejs'); %>
<script src="/exhibits-dashboard/static/libs/data_tables/datatables.min.js"></script>
<!-- app -->
<%- include('../partials/exhibits-app-common.ejs'); %>
<script src="/exhibits-dashboard/static/app/dist/user.module.min.js?<%=build_version%>"></script>
<script>
    navModule.init();
    userModule.display_user_records();
</script>
</body>
</html>