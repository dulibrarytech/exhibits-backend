<%- include('../partials/header.ejs'); %>
<style>
    .color-picker {
        background-color: none;
        outline: none;
        border: 1px solid grey;
        height: 38px;
        width: 50px;
        cursor: pointer;
    }
    #cancel-exhibit-btn {
        min-width: 100px;
    }
    .media-preview-area {
        border: 2px dashed #c8ced3;
        border-radius: 4px;
        padding: 8px;
        background: #f8f9fa;
        height: 180px;
        max-width: 280px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        margin-bottom: 8px;
    }
    .media-preview-area:has(img) {
        border-style: solid;
        border-color: #dee2e6;
        background: #fff;
    }
    .media-preview-area img {
        max-width: 100%;
        max-height: 160px;
        object-fit: contain;
        display: block;
        border-radius: 3px;
    }
    .media-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        color: #adb5bd;
    }
    .media-placeholder i {
        font-size: 2rem;
    }
    .media-placeholder span {
        font-size: 12px;
    }
    .media-preview-area:has(img) .media-placeholder {
        display: none;
    }
    #item-media-filename-display,
    #thumbnail-filename-display {
        display: inline-block;
        max-width: 280px;
        font-size: 12px;
        color: #555;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        vertical-align: middle;
    }

</style>
<body>
<%- include('../partials/nav-dashboard.ejs'); %>
<div id="right-panel" class="right-panel">
    <%- include('../partials/main-header.ejs'); %>
    <div class="content" style="min-height: 875px;">
        <div id="message"></div>
        <h1><span id="exhibit-title"></span> - Vertical Timeline Media Item</h1>
        <%- include('partials/item-vertical-timeline-item-data-card.ejs'); %>
        <div id="item-media-card" class="card">
            <div class="card-header">
                <strong class="card-title mb-3">Item Media</strong>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-6 col-md-6">
                        <div id="item-media-display" class="media-preview-area">
                            <div class="media-placeholder">
                                <i class="fa fa-file-o"></i>
                                <span>No media selected</span>
                            </div>
                        </div>
                        <p>
                            <span id="item-media-filename-display"></span>&nbsp;&nbsp;
                            <span><a id="item-media-trash" title="Remove media" href="#"
                                     style="display:none"><i class="fa fa-trash"></i></a></span>
                        </p>
                        <input type="hidden" id="item-media-uuid" name="item_media_uuid">
                        <input type="hidden" id="item-media-uuid-prev" name="item_media_uuid_prev">
                        <input type="hidden" id="item-media-type" name="item_media_type">
                        <input type="hidden" id="item-mime-type" name="item_mime_type">
                        <button type="button" class="btn btn-outline-primary"
                                id="pick-item-media-btn">
                            <i class="fa fa-file-o"></i>&nbsp;Select Media
                        </button>
                    </div>
                    <div class="col-6 col-md-6">
                        <div id="thumbnail-image-display" class="media-preview-area">
                            <div class="media-placeholder">
                                <i class="fa fa-picture-o"></i>
                                <span>No image selected</span>
                            </div>
                        </div>
                        <p>
                            <span id="thumbnail-filename-display"></span>&nbsp;&nbsp;
                            <span><a id="thumbnail-trash" title="Remove thumbnail" href="#"
                                     style="display:none"><i class="fa fa-trash"></i></a></span>
                        </p>
                        <input type="hidden" id="thumbnail-media-uuid" name="thumbnail_media_uuid">
                        <input type="hidden" id="thumbnail-media-uuid-prev" name="thumbnail_media_uuid_prev">
                        <button type="button" class="btn btn-outline-primary"
                                id="pick-thumbnail-btn"
                                data-media-type-filter="image">
                            <i class="fa fa-picture-o"></i>&nbsp;Select Thumbnail
                        </button>
                    </div>
                </div>
                <%- include('../partials/embed-item.ejs'); %>
            </div>
        </div>

        <input type="hidden" id="is-published" name="is_published">
        <div id="item-submit-card" class="card">
            <div class="card-body">
                <button class="btn btn-primary" type="button" id="edit-item-btn">
                    <i class="fa fa-edit"></i>&nbsp;&nbsp;Edit
                </button>&nbsp;&nbsp;<span class="alert alert-warning"><i class="fa fa-warning"></i> Changes made to published exhibit timeline items are immediately visible to the public</span>
            </div>
            <div class="card-footer text-muted"><small>Vertical Timeline Item</small></div>
        </div>
    </div>
    <div class="clearfix"></div>
    <%- include('../partials/footer.ejs'); %>
    <%- include('../partials/preview-html-modal.ejs'); %>
</div>
<!-- libs -->
<%- include('../partials/exhibits-libs-common.ejs'); %>
<!-- app -->
<%- include('../partials/exhibits-app-common.ejs'); %>
<script src="/exhibits-dashboard/static/app/dist/exhibits.module.min.js?<%= build_version %>"></script>
<script src="/exhibits-dashboard/static/app/dist/items.module.min.js?<%= build_version %>"></script>
<script src="/exhibits-dashboard/static/app/dist/items.common.vertical.timeline.item.form.module.min.js?<%= build_version %>"></script>
<script src="/exhibits-dashboard/static/app/dist/items.details.vertical.timeline.item.module.min.js?<%= build_version %>"></script>
<script>
    navModule.init();
    navModule.wire_nav_links();
    itemsCommonVerticalTimelineItemFormModule.init();
    itemsDetailsTimelineItemModule.init();

    document.querySelector('#edit-item-btn').addEventListener('click', (event) => {
        event.preventDefault();
        document.querySelector('.content').style.visibility = 'hidden';
        const exhibit_id = helperModule.get_parameter_by_name('exhibit_id');
        const timeline_id = helperModule.get_parameter_by_name('timeline_id');
        const item_id = helperModule.get_parameter_by_name('item_id');
        window.location.replace(`/exhibits-dashboard/items/vertical-timeline/item/media/edit?exhibit_id=${exhibit_id}&timeline_id=${timeline_id}&item_id=${item_id}`);
        return false;
    });
</script>
</body>
</html>
