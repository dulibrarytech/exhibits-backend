    <title>Exhibits @ DU Dashboard</title>
    <meta name="description" content="University of Denver Library Exhibits">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <link rel="apple-touch-icon" href="https://i.imgur.com/QRAUqs9.png">
    <link rel="shortcut icon" href="https://i.imgur.com/QRAUqs9.png">
    <link rel="icon" href="https://library.du.edu/sites/default/files/du-main-logo.svg" type="image/svg+xml">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600;700&display=swap">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/normalize.css@8.0.0/normalize.min.css" integrity="sha384-LDam9ucees55N3PLy3IESDjgo5X/gT7TTfWu0fe557edRTvEH6Y3SdM0LaZ34TxS" crossorigin="anonymous" referrerpolicy="no-referrer">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" integrity="sha384-xOolHFLEh07PJGoPkLv1IbcEPTNtaed2xpHsD9ESMhqIYd0nLMwNLD69Npy4HI+N" crossorigin="anonymous" referrerpolicy="no-referrer">
    <link rel="stylesheet" href="/exhibits-dashboard/static/assets/fonts/bootstrap-icons-1.13.1/bootstrap-icons.css" type="text/css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.min.css" integrity="sha384-wvfXpqpZZVQGK6TAh5PVlGOfQNHSoD2xbE+QkPxCAFlNEevoEH3Sl0sibVcOQVnN" crossorigin="anonymous" referrerpolicy="no-referrer">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lykmapipo/themify-icons@0.1.2/css/themify-icons.css" integrity="sha384-2CuY+hAvY/RTFXF+LPKxRYga+7RvWwnkydUXoFCoOliNUTUjTVODcuDW1rVo8Lsf" crossorigin="anonymous" referrerpolicy="no-referrer">
    <link rel="stylesheet" href="/exhibits-dashboard/static/assets/dist/dashboard.min.css?<%=build_version%>" type="text/css">
    <link rel="stylesheet" href="https://unpkg.com/dropzone@5.9.3/dist/min/dropzone.min.css" type="text/css" integrity="sha384-hKRH7ZmTc4+t+iae668SDRfEsjc7HT3VrEMKuSwiDUK4pNQXd/v9BPVpIa0OLlp7" crossorigin="anonymous" referrerpolicy="no-referrer">
    <link rel="stylesheet" href="/exhibits-dashboard/static/libs/data_tables/datatables.min.css" type="text/css">
    <script>
        // Apply sidebar collapsed state synchronously before first paint.
        // Runs before <body> exists, so targets <html> — the theme's .open
        // CSS selectors (.open aside.left-panel, .open .right-panel, etc.)
        // match any ancestor, so this works immediately.
        // Default: collapsed. Only expand if user explicitly set '0'.
        (function () {
            try {
                if (localStorage.getItem('exhibits_sidebar_collapsed') !== '0') {
                    document.documentElement.classList.add('open');
                }
            } catch (e) {
                document.documentElement.classList.add('open');
            }
        })();
    </script>
</head>
