<%#
    Unified navigation partial — replaces per-page nav fragments.

    Expects a `nav` object in template locals with:
      show_preview  {boolean}  - render the #preview-link placeholder (default false)
      back          {object}   - back link: { label, id?, href?, nav_path?, icon? }
      links         {array}    - middle links: [{ label, id?, icon, href?, nav_path?, modal?, wrapper_id? }]

    Static links use `href` (fully qualified path).
    Dynamic links use `nav_path` (relative path with {exhibit_id} etc. tokens,
    resolved at runtime by navModule.wire_nav_links()).

    Collapsed icon centering is handled at two layers:
    1. Post-aside <script> — runs synchronously before paint.
    2. navModule.apply_collapsed_centering() — runs at DOMContentLoaded,
       after double-rAF, and on each toggle click.

    The root cause of the left-alignment was Bootstrap 4's
    .navbar-expand-sm .navbar-nav { flex-direction: row } which makes
    each <li> only as wide as its icon (~20px), left-aligned in the row.
    The fix forces flex-direction:column + width:100% on the <ul> and <li>.
-%>
<%# ── Pre-paint body sync ── -%>
<script>
    if (document.documentElement.classList.contains('open')) {
        document.body.classList.add('open');
    }
</script>
<aside id="left-panel" class="left-panel">
    <nav class="navbar navbar-expand-sm navbar-default">
        <div id="main-menu" class="main-menu collapse navbar-collapse">
            <ul class="nav navbar-nav">
                <li class="sidebar-toggle-item">
                    <a href="#" id="sidebar-toggle" title="Toggle sidebar">
                        <i class="menu-icon fa fa-bars"></i><span class="nav-label">Toggle</span>
                    </a>
                </li>
                <% if (typeof nav !== 'undefined' && nav.show_preview) { %>
                <li id="preview-link"></li>
                <% } %>
                <% if (typeof nav !== 'undefined' && nav.back) { %>
                <li>
                    <a<% if (nav.back.id) { %> id="<%= nav.back.id %>"<% } %>
                       title="<%= nav.back.label %>"
                       href="<%= nav.back.href || '#' %>"
                       <% if (nav.back.nav_path) { %>data-nav-path="<%= nav.back.nav_path %>"<% } %>
                       data-keyboard="false">
                        <i class="menu-icon fa <%= nav.back.icon || 'fa-arrow-left' %>"></i><span class="nav-label"><%= nav.back.label %></span>
                    </a>
                </li>
                <% } %>
                <% if (typeof nav !== 'undefined' && nav.links && nav.links.length) { %>
                <% nav.links.forEach(function (link) { %>
                <li<% if (link.wrapper_id) { %> id="<%= link.wrapper_id %>"<% } %>>
                    <a<% if (link.id) { %> id="<%= link.id %>"<% } %>
                       title="<%= link.label %>"
                       href="<%= link.href || '#' %>"
                       <% if (link.nav_path) { %>data-nav-path="<%= link.nav_path %>"<% } %>
                       <% if (link.modal) { %>data-toggle="modal" data-target="<%= link.modal %>"<% } %>
                       data-keyboard="false">
                        <i class="menu-icon <%= link.icon %>"></i><span class="nav-label"><%= link.label %></span>
                    </a>
                </li>
                <% }); %>
                <% } %>
                <li>
                    <a title="Logout" href="#" id="logout" data-keyboard="false">
                        <i class="menu-icon fa fa-sign-out"></i><span class="nav-label">Logout</span>
                    </a>
                </li>
            </ul>
        </div>
    </nav>
</aside>
<%# ── Post-aside layout styling ──
    Runs synchronously after </aside> is parsed, before paint.
    Collapsed: centers icons, hides labels in the 83px sidebar.
    Expanded: overrides theme CSS to close the icon-text gap and
    prevent label wrapping.
    Both branches force flex-direction:column on .navbar-nav and
    width:100% on <li> to override Bootstrap's .navbar-expand-sm
    { flex-direction: row }.

    The style strings for each state live on window.__EXHIBITS_NAV_STYLES__
    so navModule.apply_collapsed_centering() (which re-applies after
    DOMContentLoaded, on sidebar toggle, and on viewport resize) reads
    from the same object — one source of truth. Edit styles here, both
    appliers pick them up.
-%>
<script>
    (function () {
        // Shared style table — see nav.module.js apply_collapsed_centering.
        window.__EXHIBITS_NAV_STYLES__ = {
            collapsed: {
                navbar:    'display:block;width:100%;',
                main_menu: 'display:block;width:100%;',
                nav_ul:    'flex-direction:column;width:100%;',
                item:      'padding:0;width:100%;',
                link:      'display:flex;justify-content:center;align-items:center;max-width:none;padding:12px 0;font-size:14px;width:100%;',
                icon:      'float:none;display:inline-block;width:auto;margin:0;font-size:20px;',
                label:     'display:none;'
            },
            expanded: {
                navbar:    'display:block;width:100%;',
                main_menu: 'display:block;width:100%;',
                nav_ul:    'flex-direction:column;width:100%;',
                item:      'padding:0;width:100%;',
                link:      'display:flex;align-items:center;max-width:none;padding:12px 15px;font-size:14px;width:100%;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;',
                icon:      'float:none;display:inline-flex;flex-shrink:0;width:auto;margin:0 10px 0 0;font-size:20px;',
                label:     'display:inline;white-space:nowrap;'
            }
        };

        var panel = document.getElementById('left-panel');
        if (!panel) return;

        var styles = window.__EXHIBITS_NAV_STYLES__[panel.offsetWidth <= 83 ? 'collapsed' : 'expanded'];

        var navbar   = panel.querySelector('.navbar');
        var mainMenu = panel.querySelector('#main-menu');
        var navUl    = panel.querySelector('#main-menu .navbar-nav');
        var items    = panel.querySelectorAll('.navbar-nav > li');
        var links    = panel.querySelectorAll('.navbar-nav > li > a');
        var icons    = panel.querySelectorAll('.navbar-nav > li > a > .menu-icon');
        var labels   = panel.querySelectorAll('.nav-label');

        if (navbar)   navbar.style.cssText   = styles.navbar;
        if (mainMenu) mainMenu.style.cssText = styles.main_menu;
        if (navUl)    navUl.style.cssText    = styles.nav_ul;
        for (var i = 0; i < items.length;  i++) items[i].style.cssText  = styles.item;
        for (var j = 0; j < links.length;  j++) links[j].style.cssText  = styles.link;
        for (var k = 0; k < icons.length;  k++) icons[k].style.cssText  = styles.icon;
        for (var m = 0; m < labels.length; m++) labels[m].style.cssText = styles.label;
    })();
</script>
