<%- include('partials/header.ejs'); %>
<body>
<%- include('partials/nav-dashboard.ejs'); %>
<div id="right-panel" class="right-panel">
    <%- include('partials/main-header.ejs'); %>
    <main id="main" class="content" tabindex="-1">
        <h1 class="visually-hidden">Search index management</h1>
        <div id="message"></div>

        <%# Hidden until the access gate confirms the user holds `manage_index`. %>
        <div id="index-management-content" style="display:none">

            <div class="card">
                <div class="card-header">
                    <strong class="card-title">Search Index Status</strong>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-3">Index</dt>
                        <dd class="col-sm-9" id="status-index">—</dd>
                        <dt class="col-sm-3">Exists</dt>
                        <dd class="col-sm-9" id="status-exists">—</dd>
                        <dt class="col-sm-3">Documents</dt>
                        <dd class="col-sm-9" id="status-count">—</dd>
                        <dt class="col-sm-3">Published exhibits</dt>
                        <dd class="col-sm-9" id="status-published">—</dd>
                    </dl>
                    <button type="button" id="refresh-status" class="btn btn-secondary mt-3">
                        <i class="fa fa-refresh" aria-hidden="true"></i> Refresh
                    </button>
                </div>
            </div>

            <div class="card mt-4 border-danger">
                <div class="card-header">
                    <strong class="card-title text-danger">Rebuild Search Index</strong>
                </div>
                <div class="card-body">
                    <p>
                        Rebuilding <strong>deletes the entire search index and recreates it empty</strong>, then
                        automatically reindexes all currently-published exhibits (their publish state is unchanged).
                        The public site's search will be incomplete until reindexing finishes. This action cannot be undone.
                    </p>
                    <button type="button" id="rebuild-index" class="btn btn-danger"
                            data-toggle="modal" data-target="#rebuild-confirm-modal">
                        <i class="fa fa-exclamation-triangle" aria-hidden="true"></i> Rebuild Index…
                    </button>
                </div>
            </div>

        </div>
    </main>
    <div class="clearfix"></div>
    <%- include('partials/footer.ejs'); %>
</div>

<%# ── Destructive-action confirmation (type-to-confirm) ── %>
<div class="modal fade" id="rebuild-confirm-modal" tabindex="-1" role="dialog"
     aria-labelledby="rebuild-confirm-title" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title h5" id="rebuild-confirm-title">Confirm index rebuild</h2>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p class="text-danger">
                    This deletes and recreates the live search index. Type <strong>REBUILD</strong> to confirm.
                </p>
                <p>
                    Afterward, <strong><span id="confirm-published-count">—</span></strong> currently-published
                    exhibit(s) will be reindexed automatically. Publish state is unchanged.
                </p>
                <label for="rebuild-confirm-input" class="visually-hidden">Type REBUILD to confirm</label>
                <input type="text" class="form-control" id="rebuild-confirm-input"
                       autocomplete="off" placeholder="REBUILD">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="rebuild-confirm-btn" disabled>Rebuild Index</button>
            </div>
        </div>
    </div>
</div>

<style>
    /* Match the dashboard content typography used by the other views (Open Sans,
       0.875rem) so the status/details text isn't oversized. Card titles and
       buttons keep their default size, as on the other views. */
    #index-management-content .card-body,
    #index-management-content .card-body p {
        font-family: 'Open Sans', sans-serif;
        font-size: 0.875rem;
    }
</style>
<!-- libs -->
<%- include('partials/exhibits-libs-common.ejs'); %>
<!-- app -->
<%- include('partials/exhibits-app-common.ejs'); %>
<script src="/exhibits-dashboard/static/app/dist/index.management.module.min.js?<%= build_version %>"></script>
<script>
    (async function () {
        await indexManagementModule.init();
    })();
</script>
</body>
</html>
