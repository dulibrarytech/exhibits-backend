<!-- Media Picker Modal -->
<style>
    #media-picker-modal .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    #media-picker-modal #media-picker-grid-container {
        transition: opacity 0.15s ease-in-out;
    }
    #media-picker-modal .media-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
        padding: 10px 0;
        overflow: hidden;
    }
    #media-picker-modal .media-card {
        border: 2px solid #dee2e6;
        border-radius: 4px;
        padding: 8px;
        cursor: pointer;
        transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
        background: #fff;
        position: relative;
        min-width: 0;
        overflow: hidden;
    }
    #media-picker-modal .media-card:hover {
        border-color: #80bdff;
        box-shadow: 0 0 0 0.15rem rgba(0, 123, 255, 0.25);
    }
    #media-picker-modal .media-card.selected {
        border-color: #007bff;
        box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.35);
    }
    #media-picker-modal .media-card.selected::after {
        content: '\f00c';
        font-family: 'FontAwesome';
        position: absolute;
        top: 6px;
        right: 6px;
        background: #007bff;
        color: #fff;
        border-radius: 50%;
        width: 22px;
        height: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
    }
    #media-picker-modal .media-card-thumbnail {
        width: 100%;
        height: 120px;
        object-fit: contain;
        background: #f8f9fa;
        border-radius: 3px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }
    #media-picker-modal .media-card-thumbnail img {
        max-width: 100%;
        max-height: 120px;
        object-fit: contain;
        display: block;
    }
    #media-picker-modal .media-card-placeholder {
        width: 100%;
        height: 120px;
        background: #f8f9fa;
        border-radius: 3px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #6c757d;
        font-size: 2rem;
        overflow: hidden;
    }
    #media-picker-modal .media-card-info {
        padding-top: 6px;
        font-size: 12px;
        line-height: 1.3;
    }
    #media-picker-modal .media-card-name {
        font-weight: 600;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        color: #333;
    }
    #media-picker-modal .media-card-type {
        color: #6c757d;
        font-size: 11px;
    }
    #media-picker-modal .media-selection-bar {
        background: #e9ecef;
        border-radius: 4px;
        padding: 8px 12px;
        font-size: 13px;
        min-height: 38px;
        display: flex;
        align-items: center;
    }
    #media-picker-modal .media-selection-bar .selection-preview {
        display: flex;
        align-items: center;
        gap: 10px;
    }
    #media-picker-modal .media-selection-bar .selection-preview img {
        width: 30px;
        height: 30px;
        object-fit: contain;
        border-radius: 3px;
    }
    #media-picker-modal .media-picker-pagination {
        display: flex;
        justify-content: center;
        padding: 10px 0;
        gap: 4px;
    }
    #media-picker-modal .media-picker-pagination .page-btn {
        min-width: 32px;
        height: 32px;
        border: 1px solid #dee2e6;
        background: #fff;
        border-radius: 4px;
        cursor: pointer;
        font-size: 13px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    #media-picker-modal .media-picker-pagination .page-btn:hover {
        background: #e9ecef;
    }
    #media-picker-modal .media-picker-pagination .page-btn.active {
        background: #007bff;
        color: #fff;
        border-color: #007bff;
    }
    #media-picker-modal .media-loading {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 60px 0;
        color: #6c757d;
    }
    #media-picker-modal .media-empty {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 60px 0;
        color: #6c757d;
        font-size: 14px;
    }
    @media (max-width: 768px) {
        #media-picker-modal .media-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>

<div class="modal fade" id="media-picker-modal" tabindex="-1" role="dialog"
     aria-labelledby="media-picker-modal-label" aria-hidden="true" data-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable" role="document">
        <div class="modal-content" style="background-color: #f2f2f2;">
            <div class="modal-header">
                <h5 class="modal-title" id="media-picker-modal-label">
                    <i class="fa fa-picture-o" aria-hidden="true"></i>&nbsp;Select Media
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body" style="min-height: 500px; overflow-x: hidden;">
                <!-- Tab Navigation -->
                <ul class="nav nav-tabs" id="media-picker-tabs" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link active" id="media-browse-tab" data-toggle="tab"
                           href="#media-browse-panel" role="tab" aria-controls="media-browse-panel"
                           aria-selected="true">Browse Library</a>
                    </li>
                    <!--
                    <li class="nav-item">
                        <a class="nav-link" id="media-add-tab" data-toggle="tab"
                           href="#media-add-panel" role="tab" aria-controls="media-add-panel"
                           aria-selected="false">Add New</a>
                    </li>
                    -->
                </ul>

                <div class="tab-content" id="media-picker-tab-content">
                    <!-- Browse Library Tab -->
                    <div class="tab-pane fade show active" id="media-browse-panel" role="tabpanel"
                         aria-labelledby="media-browse-tab">
                        <div class="row mt-3 mb-2">
                            <div class="col-8">
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text"><i class="fa fa-search" aria-hidden="true"></i></span>
                                    </div>
                                    <input type="text" class="form-control" id="media-picker-search"
                                           placeholder="Search media..." autocomplete="off">
                                </div>
                            </div>
                            <div class="col-4">
                                <select class="form-control" id="media-picker-type-filter">
                                    <option value="">All types</option>
                                    <option value="image">Images</option>
                                    <option value="video">Video</option>
                                    <option value="audio">Audio</option>
                                    <option value="pdf">PDF</option>
                                </select>
                            </div>
                        </div>

                        <!-- Media Grid -->
                        <div id="media-picker-grid-container">
                            <div class="media-loading">
                                <i class="fa fa-spinner fa-spin fa-2x" aria-hidden="true"></i>&nbsp;&nbsp;Loading media...
                            </div>
                        </div>

                        <!-- Pagination -->
                        <div id="media-picker-pagination" class="media-picker-pagination"></div>

                        <!-- Selection Bar -->
                        <div id="media-picker-selection-bar" class="media-selection-bar mt-2"
                             style="visibility: hidden;">
                            <div class="selection-preview">
                                <img id="media-picker-selection-thumb" alt="" style="display:none">
                                <span>
                                    <strong id="media-picker-selection-name"></strong>
                                    <span class="text-muted">&nbsp;|&nbsp;</span>
                                    <span id="media-picker-selection-type" class="text-muted"></span>
                                    <span id="media-picker-selection-dims" class="text-muted"></span>
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Add New Tab (placeholder for future) -->
                    <!--
                    <div class="tab-pane fade" id="media-add-panel" role="tabpanel"
                         aria-labelledby="media-add-tab">
                        <div class="mt-3 p-4 text-center text-muted">
                            <i class="fa fa-cloud-upload fa-3x mb-3" aria-hidden="true"></i>
                            <p>Use the <a href="/exhibits-dashboard/media/library">Media Library</a>
                               to add new media assets, then return here to select them.</p>
                        </div>
                    </div>
                    -->
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="media-picker-confirm-btn" disabled>
                    <i class="fa fa-check" aria-hidden="true"></i>&nbsp;Select Media
                </button>
            </div>
        </div>
    </div>
</div>
