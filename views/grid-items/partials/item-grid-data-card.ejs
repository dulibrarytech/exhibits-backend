<div id="grid-data-card" class="card">
    <div class="card-header">
        <strong class="card-title mb-3">Item Data</strong>
        <div class="btn-group float-right">
            <span id="created" style="text-align: right; font-size: x-small"></span>
        </div>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-8 col-md-8">
                <div class="row form-group">
                    <div class="col-12">
                        <div class="form-text text-muted" style="font-size: 17px"><span id="grid-text-input-label">Text
                            <small><em>(Optional)</em></small></span>
                            
                        </div>
                        <textarea id="grid-text-input" aria-labelledby="grid-text-input-label" class="form-control" name="grid_text_input"
                                  rows="4"></textarea>
                    </div>
                </div>
            </div>
            <div class="col-4 col-md-4">
                <div class="row form-group">
                    <div class="col-12">
                        <label for="grid-columns" class="form-text text-muted" style="font-size: 17px">Grid Columns <span class="badge badge-required">Required</span>
                        </label>
                        <select id="grid-columns" name="grid_columns"
                                class="form-control" required
                                aria-describedby="grid-columns-hint">
                            <option value="2">2</option>
                            <option value="3">3</option>
                            <option value="4" selected>4</option>
                        </select>
                        <small id="grid-columns-hint" class="form-text text-muted">Select the number of columns to display (2&ndash;4).</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
