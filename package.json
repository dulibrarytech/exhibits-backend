{
  "name": "exhibits-builder",
  "version": "2.0.0",
  "description": "DU Exhibits Builder Application - EBD @ DU",
  "main": "exhibits-backend.js",
  "scripts": {
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "NODE_OPTIONS=--max-old-space-size=4096 vitest --run --reporter verbose",
    "test:integration": "NODE_OPTIONS=--max-old-space-size=4096 jest --config jest.integration.config.js",
    "test:permissions": "NODE_OPTIONS=--max-old-space-size=4096 jest --config jest.integration.config.js permissions_matrix_integration authorize_check_permission_integration media_library_permissions_integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:views": "node test/smoke-views.js",
    "start": "node exhibits-backend.js",
    "build": "npm run build:js && gulp",
    "build:js": "node tools/generate-client-endpoints.js && node esbuild.config.js",
    "build:views": "gulp",
    "migrate:latest": "knex migrate:latest",
    "migrate:up": "knex migrate:up",
    "migrate:down": "knex migrate:down",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:make": "knex migrate:make",
    "test:e2e:live": "PW_MODE=live playwright test",
    "test:e2e:live:ui": "PW_MODE=live playwright test --ui",
    "test:e2e:live:external": "PW_MODE=live PW_EXTERNAL=1 playwright test --grep @external",
    "test:predeploy": "npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:e2e:live",
    "screenshots": "PW_MODE=live PW_SCREENSHOTS=1 playwright test --grep @screenshots"
  },
  "author": "fernando.reyes@du.edu",
  "license": "Apache",
  "dependencies": {
    "@elastic/elasticsearch": "^8.12.2",
    "@napi-rs/canvas": "^0.1.95",
    "ajv": "^6.12.0",
    "axios": "^1.6.7",
    "body-parser": "^1.19.0",
    "compression": "^1.7.4",
    "dompurify": "^3.4.11",
    "dotenv": "^17.4.0",
    "ejs": "^3.1.8",
    "exiftool-vendored": "^35.9.0",
    "express": "^4.17.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^3.23.3",
    "jsdom": "^29.0.0",
    "jsonwebtoken": "^9.0.0",
    "kaltura-client": "^21.20.0",
    "knex": "^2.4.2",
    "log4js": "^6.4.1",
    "memory-cache": "^0.2.0",
    "method-override": "^2.3.10",
    "multer": "^2.0.0",
    "mysql2": "^3.11.4",
    "pdfjs-dist": "^5.4.624",
    "sharp": "^0.34.5",
    "validator": "^13.7.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "1.59.1",
    "esbuild": "^0.28.0",
    "gulp": "^5.0.1",
    "gulp-clean-css": "^4.3.0",
    "gulp-concat": "^2.6.1",
    "gulp-htmlmin": "^5.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.1.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
