<!doctype html>
<!--[if lt IE 7]>      <html class="no-js lt-ie9 lt-ie8 lt-ie7" lang="en"> <![endif]-->
<!--[if IE 7]>         <html class="no-js lt-ie9 lt-ie8" lang="en"> <![endif]-->
<!--[if IE 8]>         <html class="no-js lt-ie9" lang="en"> <![endif]-->
<!--[if gt IE 8]><!--> <html class="no-js" lang="en"> <!--<![endif]-->
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>Exhibits @ DU Dashboard</title>
    <meta name="description" content="University of Denver Library Exhibits">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <link rel="apple-touch-icon" href="https://i.imgur.com/QRAUqs9.png">
    <link rel="shortcut icon" href="https://i.imgur.com/QRAUqs9.png">
    <link rel="icon" href="https://library.du.edu/sites/default/files/du-main-logo.svg" type="image/svg+xml">
    <!-- Vendor front-end assets are self-hosted (see public/libs, public/assets/fonts):
         the dashboard no longer depends on external CDNs at runtime, so a CDN outage
         can't degrade the live UI or break the e2e suite. CSP is 'self'-only for
         script/style/font (see config/helmet_config.js). -->
    <link rel="stylesheet" href="/exhibits-dashboard/static/assets/fonts/open-sans/open-sans.css" type="text/css">
    <link rel="stylesheet" href="/exhibits-dashboard/static/libs/normalize-8.x/normalize.min.css" type="text/css">
    <link rel="stylesheet" href="/exhibits-dashboard/static/libs/bootstrap-4.x/dist/css/bootstrap.min.css" type="text/css">
    <link rel="stylesheet" href="/exhibits-dashboard/static/assets/fonts/bootstrap-icons-1.13.1/bootstrap-icons.css" type="text/css">
    <link rel="stylesheet" href="/exhibits-dashboard/static/libs/font-awesome-4.7.0/css/font-awesome.min.css" type="text/css">
    <link rel="stylesheet" href="/exhibits-dashboard/static/libs/themify-icons-0.1.2/css/themify-icons.css" type="text/css">
    <link rel="stylesheet" href="/exhibits-dashboard/static/assets/dist/dashboard.min.css?<%=build_version%>" type="text/css">
    <link rel="stylesheet" href="/exhibits-dashboard/static/libs/dropzone-5.9.3/dropzone.min.css" type="text/css">
    <link rel="stylesheet" href="/exhibits-dashboard/static/libs/data_tables/datatables.min.css" type="text/css">
    <script>
        // Apply sidebar collapsed state synchronously before first paint.
        // Runs before <body> exists, so targets <html> — the theme's .open
        // CSS selectors (.open aside.left-panel, .open .right-panel, etc.)
        // match any ancestor, so this works immediately.
        // Default: collapsed. Only expand if user explicitly set '0'.
        (function () {
            try {
                if (localStorage.getItem('exhibits_sidebar_collapsed') !== '0') {
                    document.documentElement.classList.add('open');
                }
            } catch (e) {
                document.documentElement.classList.add('open');
            }
        })();
    </script>
</head>
