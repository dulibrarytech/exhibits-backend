<%- include('../partials/header.ejs'); %>
<body>
<%- include('../partials/nav-dashboard'); %>
<div id="right-panel" class="right-panel">
    <%- include('../partials/main-header.ejs'); %>
    <main id="main" class="content" tabindex="-1">
        <div id="message"></div>
        <!-- Phase 4: polite live region for keyboard-reorder announcements
             ("Moved <title> to position <n> of <total>"). Visually hidden;
             populated by reorderModule on each successful keyboard move. -->
        <div id="reorder-status" class="visually-hidden" role="status" aria-live="polite"></div>
        <h1 id="exhibit-title"></h1>
        <div id="item-card" class="card">
            <div class="card-header">
                <strong class="card-title mb-3">Item List</strong>
            </div>
            <div class="card-body">
                <table id="items" class="display">
                    <thead>
                    <tr>
                        <th>Order</th>
                        <th>Item</th>
                        <th>Child Items</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody id="item-data"></tbody>
                </table>
            </div>
        </div>
    </main>
    <div class="clearfix"></div>
    <%- include('../partials/footer.ejs'); %>
</div>
<style>
    /* Truncate long item titles in the Item column */
    .item-title-cell .item-title {
        display: inline-block;
        max-width: 260px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        vertical-align: middle;
    }

    /* Clickable thumbnail and title links */
    .item-thumbnail-link {
        flex-shrink: 0;
        line-height: 0;
    }
    .item-title-link {
        color: #333;
        text-decoration: none;
    }
    .item-title-link:hover {
        color: #005a9c;
        text-decoration: underline;
    }

    /* Child Items column icon */
    .child-items-link {
        color: #6c757d;
        font-size: 1.1rem;
        transition: color 0.15s ease-in-out;
    }
    .child-items-link:hover {
        color: #343a40;
        text-decoration: none;
    }

    /* Actions dropdown positioning */
    .item-actions-menu.dropdown-menu {
        right: 0 !important;
        left: auto !important;
        transform: none !important;
        margin-top: 0;
    }
    .item-actions-menu.dropdown-menu.show {
        right: 0 !important;
        left: auto !important;
        transform: none !important;
    }
</style>
<!-- libs -->
<%- include('../partials/exhibits-libs-common.ejs'); %>
<script src="/exhibits-dashboard/static/libs/data_tables/datatables.min.js"></script>
<!-- app -->
<%- include('../partials/exhibits-app-common.ejs'); %>
<script src="/exhibits-dashboard/static/app/dist/exhibits.module.min.js?<%=build_version%>"></script>
<script src="/exhibits-dashboard/static/app/dist/items.module.min.js?<%=build_version%>"></script>
<script src="/exhibits-dashboard/static/app/dist/items.list.displays.module.min.js?<%=build_version%>"></script>
<script>
    window.scrollTo(0, 0);
    navModule.wire_nav_links();
    itemsModule.init();
</script>
</body>
</html>
