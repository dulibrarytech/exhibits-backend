<%- include('../partials/header.ejs'); %>
<style>
    #cancel-exhibit-btn {
        min-width: 100px;
    }
    .media-preview-area {
        border: 2px dashed #c8ced3;
        border-radius: 4px;
        padding: 8px;
        background: #f8f9fa;
        height: 180px;
        max-width: 280px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        margin-bottom: 8px;
    }
    .media-preview-area:has(img) {
        border-style: solid;
        border-color: #dee2e6;
        background: #fff;
    }
    .media-preview-area img {
        max-width: 100%;
        max-height: 160px;
        object-fit: contain;
        display: block;
        border-radius: 3px;
    }
    .media-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        color: #adb5bd;
    }
    .media-placeholder i {
        font-size: 2rem;
    }
    .media-placeholder span {
        font-size: 12px;
    }
    .media-preview-area:has(img) .media-placeholder {
        display: none;
    }
    #hero-image-filename-display,
    #thumbnail-filename-display {
        display: inline-block;
        max-width: 280px;
        font-size: 12px;
        color: #555;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        vertical-align: middle;
    }
</style>
<body>
<%- include('../partials/nav-dashboard'); %>
<div id="right-panel" class="right-panel">
    <%- include('../partials/main-header.ejs'); %>
    <div class="content" style="min-height: 875px;">
        <div id="message"></div>
        <h1><span id="exhibit-title"></span></h1>
        <!-- exhibit data card -->
        <%- include('partials/exhibit-data-card.ejs'); %>
        <div id="exhibit-media-card" class="card">
            <div class="card-header">
                <strong class="card-title mb-3">Exhibit Media</strong>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-6 col-md-6">
                        <div id="hero-image-display" class="media-preview-area">
                            <div class="media-placeholder">
                                <i class="fa fa-picture-o"></i>
                                <span>No image selected</span>
                            </div>
                        </div>
                        <p>
                            <span id="hero-image-filename-display"></span>&nbsp;&nbsp;
                            <span><a id="hero-trash" title="Remove hero image" href="#"
                                     style="display:none"><i class="fa fa-trash"></i></a></span>
                        </p>
                        <input type="hidden" id="hero-image" name="hero_image">
                        <input type="hidden" id="hero-image-prev" name="hero_image-prev">
                        <input type="hidden" id="hero-image-media-uuid" name="hero_image_media_uuid">
                        <input type="hidden" id="hero-image-media-uuid-prev" name="hero_image_media_uuid_prev">
                        <button type="button" class="btn btn-outline-primary"
                                id="pick-hero-image-btn"
                                data-media-role="hero_image"
                                data-media-type-filter="image">
                            <i class="fa fa-picture-o"></i>&nbsp;Select Hero Image
                        </button>
                        <small id="hero-legacy-migrate" class="form-text text-muted" style="display:none">
                            <i class="fa fa-info-circle"></i> Using legacy file. Select a media library asset to migrate.
                        </small>
                    </div>
                    <div class="col-6 col-md-6">
                        <div id="thumbnail-image-display" class="media-preview-area">
                            <div class="media-placeholder">
                                <i class="fa fa-picture-o"></i>
                                <span>No image selected</span>
                            </div>
                        </div>
                        <p>
                            <span id="thumbnail-filename-display"></span>&nbsp;&nbsp;
                            <span><a id="thumbnail-trash" title="Remove thumbnail" href="#"
                                     style="display:none"><i class="fa fa-trash"></i></a></span>
                        </p>
                        <input type="hidden" id="thumbnail-image" name="thumbnail">
                        <input type="hidden" id="thumbnail-image-prev" name="thumbnail-prev">
                        <input type="hidden" id="thumbnail-media-uuid" name="thumbnail_media_uuid">
                        <input type="hidden" id="thumbnail-media-uuid-prev" name="thumbnail_media_uuid_prev">
                        <button type="button" class="btn btn-outline-primary"
                                id="pick-thumbnail-btn"
                                data-media-role="thumbnail"
                                data-media-type-filter="image">
                            <i class="fa fa-picture-o"></i>&nbsp;Select Thumbnail
                        </button>
                        <small id="thumbnail-legacy-migrate" class="form-text text-muted" style="display:none">
                            <i class="fa fa-info-circle"></i> Using legacy file. Select a media library asset to migrate.
                        </small>
                    </div>
                </div>
            </div>
        </div>
        <%- include('partials/exhibit-banners.ejs'); %>
        <input type="hidden" id="is-published" name="is_published">
        <div id="exhibit-submit-card" class="card">
            <div class="card-body">
                <input type="hidden" name="owner"
                       id="exhibit-owner" />
                <input type="hidden" name="page_layout"
                       id="exhibit-page-layout" value="top_nav" />
                <input type="hidden" name="exhibit_template" id="exhibit-template"
                       value="vertical_scroll"/>
                <button class="btn btn-primary" type="button" id="save-exhibit-btn">
                    <i class="fa fa-save"></i>&nbsp;&nbsp;Save
                </button>
                <button class="btn btn-outline-secondary ms-2" type="button" id="cancel-exhibit-btn">
                    <i class="fa fa-times"></i>&nbsp;&nbsp;Cancel
                </button>
            </div>
            <div class="card-footer text-muted"><small>Exhibit</small></div>
        </div>
    </div>
    <div class="clearfix"></div>
    <%- include('../partials/footer.ejs'); %>
    <%- include('../partials/preview-html-modal.ejs'); %>
    <%- include('../partials/media-picker-modal.ejs'); %>
</div>
<!-- libs -->
<%- include('../partials/exhibits-libs-common.ejs'); %>
<!-- app -->
<%- include('../partials/exhibits-app-common.ejs'); %>
<script src="/exhibits-dashboard/static/app/dist/media.picker.module.min.js?<%=build_version%>"></script>
<script src="/exhibits-dashboard/static/app/dist/exhibits.module.min.js?<%=build_version%>"></script>
<script src="/exhibits-dashboard/static/app/dist/exhibits.common.form.module.min.js?<%=build_version%>"></script>
<script src="/exhibits-dashboard/static/app/dist/exhibits.edit.form.module.min.js?<%=build_version%>"></script>
<script>
    exhibitsEditFormModule.init();
    exhibitsCommonFormModule.init();
    mediaPickerModule.init();
    navModule.wire_nav_links();

    const cancel_exhibit_btn = document.getElementById('cancel-exhibit-btn');

    cancel_exhibit_btn.addEventListener('click', function () {
        const has_unsaved_changes = check_for_unsaved_changes();
        if (has_unsaved_changes) {
            const confirm_cancel = confirm('Discard unsaved changes and return to the exhibits list?');
            if (!confirm_cancel) return;
        }
        // Redirect (customize as needed)
        window.location.href = '/exhibits-dashboard/exhibits';
    });

    function check_for_unsaved_changes() {
        const inputs = document.querySelectorAll('input, textarea, select');
        return Array.from(inputs).some(input => input.defaultValue !== input.value);
    }

</script>
</body>
</html>
