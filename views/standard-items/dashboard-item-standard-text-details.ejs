<%- include('../partials/header.ejs'); %>
<body>
<%- include('../partials/nav-dashboard'); %>
<div id="right-panel" class="right-panel">
    <%- include('../partials/main-header.ejs'); %>
    <div class="content" style="min-height: 875px;">
        <div id="message"></div>
        <h1><span id="exhibit-title"></span> - Text Item</h1>
        <div id="item-data-card" class="card">
            <div class="card-header">
                <strong class="card-title mb-3">Item Data</strong>
                <div class="btn-group float-right">
                    <span id="created" style="text-align: right; font-size: x-small"></span>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-12 col-md-12">
                        <div class="row form-group">
                            <div class="col-12">
                                <div class="form-text text-muted" style="font-size: 17px"><span id="is-required-text">Exhibit Text
                            <span class="badge badge-required">Required</span></span>
                                    &nbsp;&nbsp;<a onclick="helperModule.preview_html('item-text-input');return false;"
                                                   data-toggle="modal" data-target=".preview-html"
                                                   class="btn-xs btn-light"><span style="padding: 5px"><i
                                                    class="fa fa-code"></i> <small>Preview Field</small></span></a>
                                </div>
                                <textarea disabled id="item-text-input" class="form-control" name="item_text_input"
                                          rows="4"></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12 col-md-12">
                        <div class="row form-group">
                            <div class="col-12">
                                <small class="form-text text-muted"><i class="fa fa-exclamation-circle"></i> <em>Text
                                        will be wrapped around item by default</em></small>
                                <label class="form-text text-muted" style="font-size: 17px" for="media-padding">Wrap
                                    Text&nbsp;
                                    <input disabled type="checkbox" id="wrap-text" name="wrap_text" checked>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row" id="is-media-only-caption" style="display: none">
                    <div class="col-12 col-md-12">
                        <div class="row form-group">
                            <div class="col-12">
                                <div class="form-text text-muted" style="font-size: 17px">Caption
                                    &nbsp;&nbsp;<a
                                            onclick="helperModule.preview_html('item-caption-input');return false;"
                                            data-toggle="modal" data-target=".preview-html"
                                            class="btn-xs btn-light"><span style="padding: 5px"><i
                                                    class="fa fa-code"></i> <small>Preview Field</small></span></a>
                                </div>
                                <textarea disabled id="item-caption-input" class="form-control"
                                          name="item_caption_input"
                                          rows="4"></textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <input disabled type="radio"
               name="layout"
               id="item-layout-text-only"
               value="text_only" style="visibility: hidden"/>
        <input type="radio" name="media_width" id="item-width-50" value="50" checked style="visibility: hidden"/>
        <div id="exhibit-submit-card" class="card">
            <div class="card-body">
                <button class="btn btn-primary" type="button" id="edit-item-btn">
                    <i class="fa fa-edit"></i>&nbsp;&nbsp;Edit
                </button>&nbsp;&nbsp;<span class="alert alert-warning"><i class="fa fa-warning"></i> Changes made to published exhibit items are immediately visible to the public</span>
                <button class="btn btn-primary" type="button" id="update-item-btn" style="visibility: hidden">
                    <i class="fa fa-save"></i>&nbsp;&nbsp;Save
                </button>
            </div>
            <div class="card-footer text-muted"><small>Item</small></div>
        </div>
    </div>
    <div class="clearfix"></div>
    <%- include('../partials/footer.ejs'); %>
    <%- include('../partials/preview-html-modal.ejs'); %>
</div>
<!-- libs -->
<%- include('../partials/exhibits-libs-common.ejs'); %>
<!-- app -->
<%- include('../partials/exhibits-app-common.ejs'); %>
<script src="/exhibits-dashboard/static/app/dist/exhibits.module.min.js?<%=build_version%>"></script>
<script src="/exhibits-dashboard/static/app/dist/items.module.min.js?<%=build_version%>"></script>
<script src="/exhibits-dashboard/static/app/dist/items.common.standard.item.form.module.min.js?<%=build_version%>"></script>
<script src="/exhibits-dashboard/static/app/dist/items.details.standard.item.module.min.js?<%=build_version%>"></script>
<script>
    itemsCommonStandardItemFormModule.init();
    itemsDetailsStandardItemModule.init();
    navModule.wire_nav_links();
    document.querySelector('#edit-item-btn').addEventListener('click', (event) => {
        event.preventDefault();
        document.querySelector('.content').style.visibility = 'hidden';
        const exhibit_id = helperModule.get_parameter_by_name('exhibit_id');
        const item_id = helperModule.get_parameter_by_name('item_id');
        window.location.replace(`/exhibits-dashboard/items/standard/text/edit?exhibit_id=${exhibit_id}&item_id=${item_id}`);
        return false;
    });
</script>
</body>
</html>
