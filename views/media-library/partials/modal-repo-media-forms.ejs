<!-- Repository Media Import Modal -->
<!-- This modal opens when importing selected repository items and cannot be closed by the user -->
<!-- Each selected item gets its own form with individual save button -->
<div class="modal fade" 
     id="repo-media-modal" 
     data-bs-backdrop="static" 
     data-bs-keyboard="false"
     data-backdrop="static"
     data-keyboard="false"
     tabindex="-1" 
     aria-labelledby="repo-media-modal-title" 
     aria-hidden="true"
     role="dialog">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <strong class="modal-title" id="repo-media-modal-title">
                    <i class="fa fa-database" style="margin-right: 8px;" aria-hidden="true"></i>
                    Import Repository Media
                </strong>
                <!-- No close button - modal cannot be dismissed until all items are saved -->
            </div>
            <div class="modal-body">
                <!-- Import Summary -->
                <div class="alert alert-info mb-4" role="alert">
                    <div class="d-flex align-items-center">
                        <i class="fa fa-info-circle fa-lg" style="margin-right: 12px;" aria-hidden="true"></i>
                        <div>
                            <strong>Repository Items Selected</strong>
                            <p class="mb-0" id="repo-import-summary-text">Your selected items are ready for import to the media library.</p>
                        </div>
                    </div>
                </div>

                <!-- Instructions -->
                <div class="mb-4">
                    <p class="text-muted">
                        <i class="fa fa-pencil" style="margin-right: 6px;" aria-hidden="true"></i>
                        Please review and provide details for each repository item below. 
                        Fields marked <span class="badge badge-required">Required</span> must be completed.
                        Click <strong>Save</strong> on each item when done.
                    </p>
                </div>

                <!-- Repository Items Forms Container -->
                <div id="repo-items-forms-container" class="repo-items-forms">
                    <!-- Individual item forms will be dynamically inserted here by JavaScript -->
                </div>
            </div>
            <div class="modal-footer justify-content-between">
                <div class="text-muted">
                    <small>
                        <i class="fa fa-info-circle" style="margin-right: 6px;" aria-hidden="true"></i>
                        <span id="repo-modal-validation-message">0 of 0 items saved</span>
                    </small>
                </div>
                <div>
                    <button type="button" 
                            class="btn btn-success" 
                            id="repo-media-done-btn"
                            style="display: none;">
                        <i class="fa fa-check" style="margin-right: 6px;" aria-hidden="true"></i>
                        Done
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

