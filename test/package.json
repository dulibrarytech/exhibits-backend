{
  "name": "exhibit-record-tasks-tests",
  "version": "1.0.0",
  "description": "Unit tests for exhibit record task classes",
  "scripts": {
    "test": "jest",
    "test:views": "node smoke-views.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:integration": "jest --config test/integration/jest.config.js",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:integration:coverage": "jest --config test/integration/jest.config.js --coverage"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.1.4",
    "ejs": "^3.1.8"
  },
  "keywords": [
    "exhibit",
    "testing",
    "jest",
    "unit-tests"
  ],
  "author": "University of Denver",
  "license": "Apache-2.0"
}
