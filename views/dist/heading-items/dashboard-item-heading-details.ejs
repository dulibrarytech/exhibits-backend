<%- include('../partials/header.ejs'); %> <body> <%- include('../partials/nav-dashboard'); %> <div id="right-panel" class="right-panel"> <%- include('../partials/main-header.ejs'); %> <div class="content" style="min-height: 875px;"><div id="message"></div><h1><span id="exhibit-title"></span> - Heading</h1><div id="item-heading-card" class="card"><div class="card-header"><strong class="card-title mb-3">Heading data</strong><div class="btn-group float-right"><span id="created" style="text-align: right; font-size: x-small"></span></div></div><form id="item-heading-form" class="form-horizontal"><div class="card-body"><input id="exhibit-uuid" type="hidden" name="exhibit_uuid"><div class="row"><div class="col-12 col-md-12"><div class="row form-group"><div class="col-12"><div class="form-text text-muted" style="font-size: 17px">Heading Text &nbsp;&nbsp;<a onclick="helperModule.preview_html('item-heading-text-input');return false;" data-toggle="modal" data-target=".preview-html" class="btn-xs btn-light"><span style="padding: 5px"><i class="fa fa-code"></i> <small>Preview Field</small></span></a></div><span id="item-heading-text-error" class="is-error"></span> <textarea disabled="disabled" id="item-heading-text-input" class="form-control" name="item_heading_text_input" rows="4"></textarea></div></div></div></div></div></form></div><div id="item-submit-card" class="card"><div class="card-body"><button class="btn btn-primary" type="button" id="edit-item-btn"><i class="fa fa-edit"></i>&nbsp;&nbsp;Edit</button>&nbsp;&nbsp;<span class="alert alert-warning"><i class="fa fa-warning"></i> Changes made to published exhibit headings are immediately visible to the public</span> <button class="btn btn-primary" type="button" id="save-heading-btn" style="visibility: hidden"><i class="fa fa-save"></i>&nbsp;&nbsp;Save</button></div><div class="card-footer text-muted"><small>Heading</small></div></div></div><div class="clearfix"></div> <%- include('../partials/footer.ejs'); %> <%- include('../partials/preview-html-modal.ejs'); %> </div><!-- libs --> <%- include('../partials/exhibits-libs-common.ejs'); %> <!-- app --> <%- include('../partials/exhibits-app-common.ejs'); %> <script src="/exhibits-dashboard/static/app/dist/exhibits.module.min.js?<%=build_version%>"></script><script src="/exhibits-dashboard/static/app/dist/items.module.min.js?<%=build_version%>"></script><script src="/exhibits-dashboard/static/app/dist/items.common.heading.form.module.min.js?<%=build_version%>"></script><script src="/exhibits-dashboard/static/app/dist/items.details.heading.item.module.min.js?<%=build_version%>"></script><script>navModule.wire_nav_links();
    itemsDetailsHeadingModule.init();
    itemsCommonHeadingFormModule.init();
    document.querySelector('#edit-item-btn').addEventListener('click', (event) => {
        event.preventDefault();
        document.querySelector('.content').style.visibility = 'hidden';
        const exhibit_id = helperModule.get_parameter_by_name('exhibit_id');
        const item_id = helperModule.get_parameter_by_name('item_id');
        window.location.replace(`/exhibits-dashboard/items/heading/edit?exhibit_id=${exhibit_id}&item_id=${item_id}`);
        return false;
    });</script></body>