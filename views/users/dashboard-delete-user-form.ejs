<%- include('../partials/header.ejs'); %>
<body>
<%- include('../partials/nav-dashboard.ejs'); %>
<div id="right-panel" class="right-panel">
    <%- include('../partials/main-header.ejs'); %>
    <main id="main" class="content" tabindex="-1">
        <h1 class="visually-hidden">Delete user</h1>
        <div id="message"></div>
        <div id="delete-card" class="card">
            <div class="card-header">
                <strong class="card-title mb-3"></strong>
            </div>
            <div class="card-body">
                <div class="alert alert-danger" role="alert">
                    <i class="fa fa-exclamation" aria-hidden="true"></i> Are you sure you want to delete the user <strong><span id="delete-user"></span></strong>?&nbsp;&nbsp;
                    <button class="btn btn-danger" type="button" id="delete-user-btn">
                        <i class="fa fa-trash" aria-hidden="true"></i>&nbsp;&nbsp;<span id="delete-message">Delete</span>
                    </button>
                </div>
            </div>
        </div>
    </main>
    <div class="clearfix"></div>
    <%- include('../partials/footer.ejs'); %>
</div>
<!-- libs -->
<%- include('../partials/exhibits-libs-common.ejs'); %>
<!-- app -->
<%- include('../partials/exhibits-app-common.ejs'); %>
<script src="/exhibits-dashboard/static/app/user.module.js"></script>
<script>
    (async function() {
        navModule.init();
        navModule.wire_nav_links();
        const user_id = helperModule.get_parameter_by_name('user_id');
        const user = await userModule.display_user(user_id);
        document.querySelector('#delete-user').innerHTML = `${user.first_name} ${user.last_name}`;
        document.querySelector('#delete-user-btn').addEventListener('click', userModule.delete_user);
        helperModule.show_form();
    })();
</script>
</body>
</html>
