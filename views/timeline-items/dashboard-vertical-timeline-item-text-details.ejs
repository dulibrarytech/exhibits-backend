<body>
<%- include('../partials/nav-dashboard.ejs'); %>
<div id="right-panel" class="right-panel">
    <%- include('../partials/main-header.ejs'); %>
    <main id="main" class="content" tabindex="-1">
        <div id="message"></div>
        <h1><span id="exhibit-title"></span> - Vertical Timeline Text Item</h1>
        <!-- item data card -->
        <div id="item-data-card" class="card">
            <div class="card-header">
                <strong class="card-title mb-3">Item Data</strong>
                <div class="btn-group float-right">
                    <span id="created" style="text-align: right; font-size: x-small"></span>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-12 col-md-12">
                        <div class="row form-group">
                            <div class="col-12">
                                <div class="form-text text-muted" style="font-size: 17px">
                                    Title <small><em>(Optional)</em></small>
                                    &nbsp;&nbsp;<a onclick="helperModule.preview_html('item-title-input');return false;" data-toggle="modal" data-target=".preview-html" class="btn-xs btn-light"><span style="padding: 5px"><i class="fa fa-code" aria-hidden="true"></i> <small>Preview Field</small></span></a>
                                </div>
                                <span id="item-title-error" class="is-error"></span>
                                <textarea disabled id="item-title-input" class="form-control" name="item_title_input"
                                          rows="4"></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12 col-md-12">
                        <div class="row form-group">
                            <div class="col-12">
                                <div class="form-text text-muted" style="font-size: 17px"><span style="color: darkred">*</span>Date</div>
                                <input disabled class="form-control" id="item-date-input" type="date" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12 col-md-12">
                        <div class="row form-group">
                            <div class="col-12">
                                <div class="form-text text-muted" style="font-size: 17px">Exhibit Text <small><em>(Optional)</em></small>
                                    &nbsp;&nbsp;<a onclick="helperModule.preview_html('item-text-input');return false;" data-toggle="modal" data-target=".preview-html" class="btn-xs btn-light"><span style="padding: 5px"><i class="fa fa-code" aria-hidden="true"></i> <small>Preview Field</small></span></a>
                                </div>
                                <textarea disabled id="item-text-input" class="form-control" name="item_text_input"
                                          rows="4"></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12 col-md-12">
                        <div class="row form-group">
                            <div class="col-12">
                                <div class="form-text text-muted" style="font-size: 17px">Pop-up Window Description <small><em>(Optional)</em></small>
                                    &nbsp;&nbsp;<a onclick="helperModule.preview_html('item-description-input');return false;" data-toggle="modal" data-target=".preview-html" class="btn-xs btn-light"><span style="padding: 5px"><i class="fa fa-code" aria-hidden="true"></i> <small>Preview Field</small></span></a>
                                </div>
                                <textarea disabled id="item-description-input" class="form-control" name="item_description_input"
                                          rows="4"></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                <!--
                <div class="row">
                    <div class="col-12 col-md-12">
                        <div class="row form-group">
                            <div class="col-12">
                                <div class="form-text text-muted" style="font-size: 17px">Caption <small><em>(Optional)</em></small>
                                    &nbsp;&nbsp;<a onclick="helperModule.preview_html('item-caption-input');return false;" data-toggle="modal" data-target=".preview-html" class="btn-xs btn-light"><span style="padding: 5px"><i class="fa fa-code" aria-hidden="true"></i> <small>Preview Field</small></span></a>
                                </div>
                                <textarea disabled id="item-caption-input" class="form-control" name="item_caption_input" rows="4"></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                -->
            </div>
        </div>
