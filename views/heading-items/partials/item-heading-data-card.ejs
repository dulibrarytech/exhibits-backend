<div id="item-heading-card" class="card">
    <div class="card-header">
        <strong class="card-title mb-3">Heading Data</strong>
        <div class="btn-group float-right">
            <span id="created" style="text-align: right; font-size: x-small"></span>
        </div>
    </div>
    <form id="item-heading-form" class="form-horizontal">
        <div class="card-body">
            <input id="exhibit-uuid" type="hidden" name="exhibit_uuid">
            <div class="row">
                <div class="col-7 col-md-7">
                    <div class="row form-group">
                        <div class="col-7 col-md-7">
                            <div class="form-text text-muted" style="font-size: 17px">
                                Heading Type <span class="badge badge-required">Required</span>
                            </div>
                            <span id="item-heading-type-error" class="is-error"></span>
                            <div class="input-group">
                                <select <%= (typeof is_details !== 'undefined' && is_details) ? 'disabled' : '' %> name="item_heading_type_input" id="item-heading-type-input"
                                        class="form-control-lg form-control text-muted" style="height: 40px">
                                    <option value="">Select From Menu</option>
                                    <option value="">----------</option>
                                    <option value="heading">Heading</option>
                                    <option value="subheading">Subheading</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-12 col-md-12">
                    <div class="row form-group">
                        <div class="col-12">
                            <div class="form-text text-muted" style="font-size: 17px">
                                Heading Text <span class="badge badge-required">Required</span>
                                &nbsp;&nbsp;<a onclick="helperModule.preview_html('item-heading-text-input');return false;" data-toggle="modal" data-target=".preview-html" class="btn-xs btn-light"><span style="padding: 5px"><i class="fa fa-code"></i> <small>Preview Field</small></span></a>
                            </div>
                            <span id="item-heading-text-error" class="is-error"></span>
                            <textarea <%= (typeof is_details !== 'undefined' && is_details) ? 'disabled' : '' %> id="item-heading-text-input" class="form-control" name="item_heading_text_input"
                                      rows="4"></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
